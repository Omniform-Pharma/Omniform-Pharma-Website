# .gitignore — files and folders that should NOT be committed to Git
# (node_modules are huge; .env files contain secrets)

# ── Dependencies ──────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build output ──────────────────────────
dist/
build/
.vite/

# ── Environment variables (NEVER commit these) ────────────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── Logs ─────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*

# ── Editor / OS files ────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
.vscode/
.idea/

# ── Testing ──────────────────────────────
coverage/


# Design Files
Pharmaceutical Company Website UI/