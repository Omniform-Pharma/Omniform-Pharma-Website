# Server port
PORT=5000

# Allowed frontend origin for CORS
CLIENT_URL=http://localhost:5173

# Future database connection string
MONGODB_URI=your_mongodb_connection_string_here

# SMTP settings for contact form email (Nodemailer)
# Recommended: use a transactional provider (Brevo/SendGrid/Mailgun) or
# your email host SMTP. These values must be set for /api/contact to send mail.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<your_email_address>
SMTP_PASS=<your_email_password_or_app_password>
SMTP_SECURE=false

# Email envelope settings
MAIL_FROM=Omniform Pharma Website <inquiry@omniformpharma.com>
MAIL_TO=inquiry@omniformpharma.com


